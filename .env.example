# Copy this file to .env and fill in real values. Never commit .env.

# GitHub personal access token (public repo read access is sufficient).
# Increases the REST API rate limit from 60 to 5000 requests/hour.
GITHUB_TOKEN=ghp_your_token_here

# Which LLM backend to use. Switch providers by changing only this value.
# Supported: anthropic  (openai planned)
LLM_PROVIDER=anthropic

# Anthropic API key. Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Maximum number of open issues to fetch and triage.
MAX_ISSUES=50

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
